import  java.util.Scanner;
public class Lab2 {
    public static void main(String[] args) {
        Scanner in = new Scanner(System.in);
        int x, before = 0;
        int counter = 1;
        int countermax = 0;
        do{
            System.out.print("Enter you number : ");
            x = in.nextInt();
            if(before == x) {
                counter++;
            }
            else if(x!=0) {
                before = x;
                if(counter > countermax) {
                    countermax = counter;

                }
                counter = 1;
            }
        }while(x!=0);
    }
}
