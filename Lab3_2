public class Lab2 {
    public static void main(String[] args) {
        int[] arr = {1, 2, 2, 2, 3, 4, 4, 2, 5};

        int L = arr.length;
        for(int i = 0; i < L - 1;i++){
            if(arr[i] == arr[i+1]) {
                for(int j = i + 1; j < L;j++) {
                    arr[j-1] = arr[j];
                }
                L--;
                i--;
            }
        }
        for(int m = 0; m < L;m++) System.out.println(arr[m]);
    }
}
